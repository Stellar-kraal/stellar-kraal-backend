# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
FRONTEND_URL=http://localhost:3000

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="file:./dev.db"

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# The value below is a mock/dev placeholder — never use it in production.
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production
JWT_EXPIRES_IN=24h

# JWT rotation (dual-key overlap window) — see docs/ops/secrets-rotation.md
# and `npm run rotate:jwt-secret`. Leave unset unless a rotation is in progress.
JWT_SECRET_PREVIOUS=
JWT_SECRET_ROTATED_AT=
JWT_ROTATION_OVERLAP_MS=3600000

# ─── Secrets management ────────────────────────────────────────────────────────
# Which SecretsProvider resolves secret references (src/lib/secretsProvider.ts).
# `mock` (default) is for local dev/CI only and never touches real secrets.
SECRETS_PROVIDER=mock

# ─── Session cookie ───────────────────────────────────────────────────────────
# The login endpoint issues the JWT as an HttpOnly session cookie so it is never
# exposed to frontend JavaScript. Tune the cookie attributes below.
#
# COOKIE_SECURE   — send the cookie only over HTTPS. Defaults to true when
#                   NODE_ENV=production, false otherwise (so local HTTP works).
# COOKIE_SAME_SITE — lax | strict | none. `lax` mitigates CSRF and is the safe
#                   default. Use `none` (requires COOKIE_SECURE=true) only when
#                   the frontend is served from a different site than the API.
# COOKIE_DOMAIN   — optional cookie scope, e.g. .stellarkraal.app. Empty = host-only.
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
COOKIE_DOMAIN=

# ─── Stellar / Soroban ────────────────────────────────────────────────────────
STELLAR_NETWORK=testnet
RPC_URL=https://soroban-testnet.stellar.org

# Deployed Soroban contract ID (C... address)
CONTRACT_ID=CAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAD2KM

# Server-side SEP-10 auth signing keypair (S... secret key)
# Generate with: stellar keys generate --network testnet auth-server
AUTH_SERVER_SECRET_KEY=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Server-side oracle keypair for on-chain transactions (S... secret key)
# Generate with: stellar keys generate --network testnet oracle-server
ORACLE_SERVER_SECRET_KEY=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Legacy fallback key (kept for backward compatibility)
SERVER_SECRET_KEY=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── Polling ──────────────────────────────────────────────────────────────────
# How often (ms) to poll Soroban for new events
POLL_INTERVAL_MS=15000

# Starting ledger for event polling (0 = latest)
START_LEDGER=0

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ─── Bulk Retirement ────────────────────────────────────────────────────────
# Maximum number of loans (credits) allowed per bulk retirement request
BULK_RETIREMENT_MAX_BATCH_SIZE=100

# Maximum number of retire_loan operations packed into a single Soroban transaction
SOROBAN_MAX_OPS_PER_TX=20
