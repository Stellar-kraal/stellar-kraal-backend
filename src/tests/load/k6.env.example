# ─── k6 Load Test Environment Variables ──────────────────────────────────────
# Copy this file to .env.load and fill in real values before running.
# Never commit .env.load — it is gitignored.
#
# Usage:
#   k6 run --env-file .env.load src/tests/load/scenarios/<scenario>.js
#
# Or pass inline:
#   k6 run -e BASE_URL=http://localhost:3001 -e FARMER_TOKEN=<jwt> src/tests/load/scenarios/01-health.js

# ─── Target ───────────────────────────────────────────────────────────────────
# Base URL of the running StellarKraal API (no trailing slash)
BASE_URL=http://localhost:3001

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Pre-generated long-lived JWT for a FARMER account (used in write scenarios).
# Generate with: node src/tests/load/scripts/generate-tokens.mjs
FARMER_TOKEN=

# Pre-generated long-lived JWT for an INVESTOR account (used in market-view scenario).
INVESTOR_TOKEN=

# ─── Tuning ───────────────────────────────────────────────────────────────────
# Virtual user counts — can be overridden per run
VUS_LOW=10
VUS_MID=50
VUS_HIGH=100

# Test duration (default for full baseline run)
DURATION=60s

# Smoke run duration (used in CI)
SMOKE_DURATION=30s
SMOKE_VUS=10

# ─── Thresholds ───────────────────────────────────────────────────────────────
# p95 latency ceiling (ms) — CI smoke test fails if exceeded
P95_THRESHOLD_MS=2000

# Maximum acceptable error rate (0–1)
ERROR_RATE_THRESHOLD=0.05
