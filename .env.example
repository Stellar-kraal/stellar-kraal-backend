# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
FRONTEND_URL=http://localhost:3000

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="file:./dev.db"

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production
JWT_EXPIRES_IN=24h

# ─── Session cookie ───────────────────────────────────────────────────────────
# The login endpoint issues the JWT as an HttpOnly session cookie so it is never
# exposed to frontend JavaScript. Tune the cookie attributes below.
#
# COOKIE_SECURE   — send the cookie only over HTTPS. Defaults to true when
#                   NODE_ENV=production, false otherwise (so local HTTP works).
# COOKIE_SAME_SITE — lax | strict | none. `lax` mitigates CSRF and is the safe
#                   default. Use `none` (requires COOKIE_SECURE=true) only when
#                   the frontend is served from a different site than the API.
# COOKIE_DOMAIN   — optional cookie scope, e.g. .stellarkraal.app. Empty = host-only.
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
COOKIE_DOMAIN=

# ─── Stellar / Soroban ────────────────────────────────────────────────────────
STELLAR_NETWORK=testnet
RPC_URL=https://soroban-testnet.stellar.org

# Deployed Soroban contract ID (C... address)
CONTRACT_ID=CAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAD2KM

# Server-side oracle keypair (S... secret key)
# Generate with: stellar keys generate --network testnet oracle-server
SERVER_SECRET_KEY=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── Polling ──────────────────────────────────────────────────────────────────
# How often (ms) to poll Soroban for new events
POLL_INTERVAL_MS=15000

# Starting ledger for event polling (0 = latest)
START_LEDGER=0

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
