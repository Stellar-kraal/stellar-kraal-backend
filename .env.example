# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
FRONTEND_URL=http://localhost:3000

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="file:./dev.db"

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production
JWT_EXPIRES_IN=24h

# ─── Stellar / Soroban ────────────────────────────────────────────────────────
STELLAR_NETWORK=testnet
RPC_URL=https://soroban-testnet.stellar.org

# Deployed Soroban contract ID (C... address)
CONTRACT_ID=CAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAD2KM

# Server-side oracle keypair (S... secret key)
# Generate with: stellar keys generate --network testnet oracle-server
SERVER_SECRET_KEY=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── Polling ──────────────────────────────────────────────────────────────────
# How often (ms) to poll Soroban for new events
POLL_INTERVAL_MS=15000

# Starting ledger for event polling (0 = latest)
START_LEDGER=0

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ─── Monitoring / Anomaly Detection (src/monitoring/) ──────────────────────────
# Independent service — see docs/ops/anomaly-detection.md. Reuses CONTRACT_ID
# and STELLAR_NETWORK above; does NOT need JWT_SECRET, SERVER_SECRET_KEY, or
# DATABASE_URL.

# Horizon endpoint to stream from (defaults per STELLAR_NETWORK if unset)
HORIZON_URL=https://horizon-testnet.stellar.org

# Port for the monitoring service's /health endpoint
MONITOR_PORT=3002

# Max age (ms) since an on-chain event's confirmation before /health reports unhealthy
MAX_EVENT_LAG_MS=10000

# Slack/PagerDuty-compatible incoming webhook URL alerts are POSTed to
WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
# 'slack' formats a Slack-compatible payload; 'generic' posts the raw anomaly as JSON
WEBHOOK_FORMAT=slack

# Cooldown (seconds) before the same anomaly is re-alerted
ALERT_COOLDOWN_SECONDS=900

# Rule: large value invocation (wash-trading-style anomaly)
LARGE_VALUE_FUNCTIONS=mint_collateral
LARGE_VALUE_THRESHOLD=50000

# Rule: oracle price deviation
ORACLE_PRICE_FUNCTIONS=mint_collateral,set_price
ORACLE_DEVIATION_THRESHOLD_PCT=20
ORACLE_DEVIATION_MIN_SAMPLES=3

# Rule: unauthorized entry-point calls
PRIVILEGED_FUNCTIONS=mint_collateral,set_price
# Comma-separated allowlist of G-addresses permitted to call PRIVILEGED_FUNCTIONS.
# Leave empty to only flag failed (contract error) calls, without allowlist enforcement.
ALLOWED_INVOKER_ACCOUNTS=

# Rule: transaction volume spike
VOLUME_WINDOW_SECONDS=60
VOLUME_BASELINE_WINDOWS=10
VOLUME_SPIKE_MULTIPLIER=3
VOLUME_SPIKE_MIN_COUNT=10
