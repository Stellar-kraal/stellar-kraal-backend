# .env.e2e.example
#
# Copy to .env.e2e and fill in real values before running E2E tests.
# Never commit .env.e2e — it is listed in .gitignore.
#
# Usage:
#   cp .env.e2e.example .env.e2e
#   # edit .env.e2e
#   npm run test:e2e

# ─── Backend ─────────────────────────────────────────────────────────────────
# URL of the running backend. Start with: npm run dev
E2E_API_URL=http://localhost:3001

# ─── Stellar / Soroban ────────────────────────────────────────────────────────
E2E_NETWORK=testnet
E2E_RPC_URL=https://soroban-testnet.stellar.org

# Deployed contract ID for E2E testing.
# If E2E_DEPLOY_CONTRACT=true this is overridden after deployment.
E2E_CONTRACT_ID=CAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAD2KM

# Server-side auth secret key (must match running backend's AUTH_SERVER_SECRET_KEY)
E2E_AUTH_SERVER_SECRET_KEY=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Server-side oracle secret key (must match running backend's ORACLE_SERVER_SECRET_KEY)
E2E_ORACLE_SERVER_SECRET_KEY=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Legacy server secret key fallback
E2E_SERVER_SECRET_KEY=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── Contract Deployment ─────────────────────────────────────────────────────
# Set to true in CI to deploy a fresh contract instance before each run.
# Requires stellar-cli to be installed and the WASM to be pre-built.
E2E_DEPLOY_CONTRACT=false

# ─── Database ─────────────────────────────────────────────────────────────────
# Separate SQLite file for E2E tests (wiped on each run).
DATABASE_URL=file:./e2e.db

# ─── Backend auth (must match the running backend) ────────────────────────────
JWT_SECRET=your-e2e-jwt-secret-change-this
JWT_EXPIRES_IN=2h

# ─── Test behaviour ───────────────────────────────────────────────────────────
# Maximum milliseconds to wait for an on-chain confirmation in any single step.
E2E_ON_CHAIN_TIMEOUT_MS=90000

# Print step-by-step progress to stdout.
E2E_VERBOSE=true
