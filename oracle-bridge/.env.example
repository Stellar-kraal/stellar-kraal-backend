# Copy to .env at the repo root (docker-compose.yml reads it automatically)
# or export these directly when running the bridge standalone with `npm start`.

# testnet | mainnet | futurenet | standalone
ORACLE_BRIDGE_NETWORK=testnet
ORACLE_BRIDGE_RPC_URL=https://soroban-testnet.stellar.org

# Deployed StellarKraal contract ID
ORACLE_BRIDGE_CONTRACT_ID=

# Reference to the oracle signing key — NEVER the raw secret key itself.
#   - Local/dev/CI: mock://oracle-bridge/signing-key  (requires SECRETS_PROVIDER=mock)
#   - Production:   your real secrets manager's reference (e.g. an AWS
#                   Secrets Manager ARN) — requires an implemented
#                   SecretsProvider; see docs/ops/oracle-bridge-dr.md
ORACLE_BRIDGE_SIGNING_KEY_SECRET_REF=mock://oracle-bridge/signing-key

# mock | aws  (aws is a documented extension point, not yet implemented)
ORACLE_BRIDGE_SECRETS_PROVIDER=mock

# When true (default), the bridge logs what it would submit instead of
# sending a real Soroban transaction. Keep true for local dev, CI, and DR
# drills unless you specifically intend to submit to a live network.
ORACLE_BRIDGE_DRY_RUN=true

ORACLE_BRIDGE_BACKUP_INTERVAL_MS=30000
ORACLE_BRIDGE_SUBMIT_INTERVAL_MS=60000
