{
  "name": "stellarkraal-oracle-bridge",
  "version": "1.0.0",
  "description": "StellarKraal oracle bridge — off-chain price submission to the Soroban contract, with primary/standby disaster recovery",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only --exit-child src/index.ts",
    "backup": "node dist/cli/backup.js",
    "restore": "node dist/cli/restore.js",
    "promote": "node dist/cli/promote.js",
    "dev:backup": "ts-node src/cli/backup.ts",
    "dev:restore": "ts-node src/cli/restore.ts",
    "dev:promote": "ts-node src/cli/promote.ts",
    "typecheck": "tsc --noEmit",
    "test": "jest --runInBand"
  },
  "dependencies": {
    "@stellar/stellar-sdk": "12.3.0"
  },
  "devDependencies": {
    "@types/jest": "29.5.14",
    "@types/node": "20.17.6",
    "jest": "29.7.0",
    "ts-jest": "29.2.5",
    "ts-node": "10.9.2",
    "ts-node-dev": "2.0.0",
    "typescript": "5.6.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
